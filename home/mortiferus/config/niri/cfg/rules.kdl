// ────────────── Globale Fenster-Optik ──────────────
window-rule {
    geometry-corner-radius 12
    clip-to-geometry true
    opacity 1.0
    draw-border-with-background false 
}

    layer-rule {
        match namespace="^noctalia-wallpaper*"
        place-within-backdrop true
    }

window-rule {
    // Wir ignorieren die App-ID und gehen rein auf den Fensternamen
    match title="^Steam$"
    open-on-workspace "2"
    open-fullscreen false

    // Das hier ist wichtig: Es zwingt Niri, das Fenster
    // auch dann zu verschieben, wenn es eigentlich schon "platziert" ist.

    block-out-from "screen-capture" // Nur ein Beispiel-Property zum Triggern
} 

window-rule {
    // Vesktop erkennt man meist am App-ID oder Titel
    match app-id="vesktop"
    
    // Schiebe es auf Workspace 2
    open-on-workspace "2"
    
    // Optional: Automatisch maximieren, damit es den Platz nutzt
    default-column-width { proportion 1.0; }
}

window-rule {
    // Lutris (deckt beide IDs ab)
    match app-id="net.lutris.Lutris"
    match app-id="lutris"
    open-on-workspace "2"
}

window-rule {
    // Heroic Games Launcher
    match app-id="com.heroicgameslauncher.hgl"
    match app-id="heroic"
    open-on-workspace "2"
}

window-rule {
    // Firefox erkennt man am besten über die app-id
    match app-id="firefox"
    open-on-workspace "1"
}
window-rule {
    // Firefox erkennt man am besten über die app-id
    match app-id="brave"
    open-on-workspace "1"
}
window-rule {
    match app-id="zen-beta"

    open-on-workspace "1"
    open-floating true
}

