layout {

    focus-ring {
        active-color   "#0058bd"
        inactive-color "#f9f9ff"
        urgent-color   "#ba1a1a"
    }

    border {
        active-color   "#0058bd"
        inactive-color "#f9f9ff"
        urgent-color   "#ba1a1a"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#0058bd"
        inactive-color "#2771df"
        urgent-color   "#ba1a1a"
    }

    insert-hint {
        color "#0058bd80"
    }
}

recent-windows {
    highlight {
        active-color "#0058bd"
        urgent-color "#ba1a1a"
    }
}
