layout {

    focus-ring {
        active-color   "#85522f"
        inactive-color "#fff8f5"
        urgent-color   "#ba1a1a"
    }

    border {
        active-color   "#85522f"
        inactive-color "#fff8f5"
        urgent-color   "#ba1a1a"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#85522f"
        inactive-color "#ffdcc7"
        urgent-color   "#ba1a1a"
    }

    insert-hint {
        color "#85522f80"
    }
}

recent-windows {
    highlight {
        active-color "#85522f"
        urgent-color "#ba1a1a"
    }
}
