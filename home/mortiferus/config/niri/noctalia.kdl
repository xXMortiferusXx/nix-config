layout {

    focus-ring {
        active-color   "#3e6187"
        inactive-color "#faf9fc"
        urgent-color   "#ba1a1a"
    }

    border {
        active-color   "#3e6187"
        inactive-color "#faf9fc"
        urgent-color   "#ba1a1a"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#3e6187"
        inactive-color "#d1e4ff"
        urgent-color   "#ba1a1a"
    }

    insert-hint {
        color "#3e618780"
    }
}

recent-windows {
    highlight {
        active-color "#3e6187"
        urgent-color "#ba1a1a"
    }
}
