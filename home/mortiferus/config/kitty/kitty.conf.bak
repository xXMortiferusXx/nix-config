# --- Optik & Transparenz ---
background_opacity 0.85
# (Falls Niri Blur unterstützt, sieht das mit 0.85 richtig edel aus)

# --- Fenster-Styling ---
window_padding_width 10
# Ein bisschen Platz zum Rand wirkt wunder, damit der Text nicht "klebt"

# --- Cursor-Action (Einer der besten Effekte) ---
cursor_shape beam
cursor_beam_thickness 1.5
cursor_blink_interval 0.5

# --- Schriften ---
# Wenn du "JetBrainsMono Nerd Font" installiert hast, nimm die!
font_family      JetBrainsMono Nerd Font
font_size        11.0

# --- Performance & Verhalten ---
repaint_delay    8
input_delay      3
sync_to_monitor  yes

# --- Tab Bar (Falls du Tabs nutzt) ---
tab_bar_style powerline
active_tab_foreground   #000
active_tab_background   #eee

# --- Weiche Bewegungen ---
# Reduziert das "Springen" beim Scrollen
wheel_scroll_multiplier 5.0
touch_scroll_multiplier 5.0

# --- Cursor-Effekte (wie in modernen IDEs) ---
# Der Cursor "gleitet" statt zu springen
cursor_trail 1
cursor_trail_decay 0.1 0.4
cursor_trail_start_threshold 2

# --- Terminal Bell (kein nerviges Blinken/Piepen) ---
enable_audio_bell no
window_alert_on_bell yes

# --- FPS Limit (für flüssige Animationen) ---
# Stell das auf die Hz-Zahl deines Monitors (z.B. 144 oder 165)
fps_limit 165
